# Copy this file to .env and fill in real values. Never commit the real .env file.

# Google Maps API keys.
# Optional for quick testing (a "for development purposes only" watermark will show on
# the Android map without a key), but recommended for a clean demo/viva recording.
# Get keys from https://console.cloud.google.com/ (enable "Maps SDK for Android/iOS").
GOOGLE_MAPS_API_KEY_ANDROID=
GOOGLE_MAPS_API_KEY_IOS=

# Optional Firebase configuration.
# If these are left blank, GeoQuest automatically falls back to a local mock
# authentication + AsyncStorage persistence layer so the app still fully works offline.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Demo/development mode.
# When true, exposes a developer-only "teleport" control in the app that simulates
# being near a cache, so the discovery workflow can be tested without travelling to
# every real GPS location. This does NOT change how unlocking works in production -
# it only overrides the location value that is fed into the same real distance check.
EXPO_PUBLIC_DEV_MODE=true
